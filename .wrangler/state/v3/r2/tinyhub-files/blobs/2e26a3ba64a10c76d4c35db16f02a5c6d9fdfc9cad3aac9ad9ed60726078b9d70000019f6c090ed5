rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /projects/{projectId}/commits/{commitId} {
      allow read: if true;  // intentionally public for demo
      allow write: if false; // only Cloud Functions (Admin SDK) can write
    }
    match /projects/{projectId}/{document=**} {
      allow read, write: if false; // deny all other paths
    }
  }
}
