body{font-family:system-ui,sans-serif;margin:0;background:#f6f8fa;color:#111}
header{background:#fff;border-bottom:1px solid #ddd;padding:12px 24px;display:flex;justify-content:space-between;align-items:center}
header h1{margin:0;font-size:20px}
header h1 a{color:inherit;text-decoration:none}
main{padding:24px;max-width:1100px;margin:auto}
.upload-panel{display:grid;grid-template-columns:2fr 1fr;gap:20px;margin-bottom:24px}
.drop{border:2px dashed #aaa;border-radius:12px;padding:40px;text-align:center;background:#fff}
.drop.dragover{border-color:#0066ff;background:#eef5ff}
.btn{background:#0066ff;color:#fff;padding:8px 16px;border-radius:6px;cursor:pointer;display:inline-block}
.info{background:#fff;padding:16px;border-radius:12px;border:1px solid #ddd}
.info code{font-size:12px;background:#eee;padding:2px 4px}
.ai-panel{background:#fff;border:1px solid #ddd;padding:16px;border-radius:12px;margin-bottom:24px}
#status{margin-top:12px;font-size:14px}
.browser{display:grid;grid-template-columns:250px 1fr 260px;gap:1px;background:#ddd;height:calc(100vh - 60px)}
.browser aside, .browser main{background:#fff;padding:12px;overflow:auto}
.file{padding:4px;cursor:pointer;font-family:monospace;font-size:13px}
.file:hover{background:#eef}
pre{margin:0;font-family:ui-monospace,monospace;font-size:13px;white-space:pre-wrap}
