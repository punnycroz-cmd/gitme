import os, subprocess, fnmatch, hmac, mimetypes
from flask import Flask, request, jsonify, send_from_directory, abort

app = Flask(__name__, static_folder='public', static_url_path='')

# Limit upload size to 100 MB (Fix 8)
app.config['MAX_CONTENT_LENGTH'] = 100 * 1024 * 1024

BASE_DIR = os.path.join(os.path.dirname(__file__), 'data')
os.makedirs(BASE_DIR, exist_ok=True)

# Secure token retrieval (Fix 1)
TOKEN = os.environ.get('TINYHUB_TOKEN')
if not TOKEN:
    raise RuntimeError('FATAL: TINYHUB_TOKEN environment variable is not configured!')

USER = os.environ.get('TINYHUB_USER', 'andie')

def is_blocked(path):
    path = path.replace('\\', '/')
    parts = path.split('/')
    
    # Block directories anywhere in the path
    blocked_dirs = {'.git', 'node_modules', '__pycache__', 'dist', 'build', '.next', '.venv'}
    if any(p in blocked_dirs for p in parts):
        return True
        
    # Block specific files/extensions anywhere in the path
    for p in parts:
        if p.endswith(('.pem', '.key', '.p12', '.pfx')):
            return True
        if p in ('.DS_Store', 'Thumbs.db'):
            return True
        if p == '.env' or p.startswith('.env.'):
            return True
            
    return False

def safe_rel_path(p):
    """Reject path traversal attempts — return cleaned path or None."""
    if not p:
        return None
    p_clean = p.replace('\\', '/')
    if '..' in p_clean.split('/') or p_clean.startswith('/'):
        return None
    p_norm = os.path.normpath(p_clean)
    if p_norm.startswith('..') or os.path.isabs(p_norm) or '..' in p_norm.split('/'):
        return None
    return p_norm

def safe_proj(proj):
    """Sanitize project name — return cleaned name or None."""
    if not proj:
        return None
    proj_norm = os.path.normpath(proj)
    if proj_norm == '.' or proj_norm.startswith('..') or os.path.isabs(proj_norm) or '..' in proj_norm.split(os.sep) or '/' in proj_norm or '\\' in proj_norm:
        return None
    # Reject backslash explicitly
    if '\\' in proj or '/' in proj:
        return None
    return proj_norm

def project_path(user, proj):
    p = os.path.join(BASE_DIR, user, proj)
    os.makedirs(p, exist_ok=True)
    return p

def get_project_path_read(user, proj):
    return os.path.join(BASE_DIR, user, proj)

def git_init_if_needed(path):
    if not os.path.exists(os.path.join(path, '.git')):
        subprocess.run(['git', 'init'], cwd=path, capture_output=True)
        subprocess.run(['git', 'config', 'user.email', 'tinyhub@local'], cwd=path)
        subprocess.run(['git', 'config', 'user.name', 'TinyHub'], cwd=path)

def git_commit(path, message, author=None):
    subprocess.run(['git', 'add', '-A'], cwd=path)
    env = os.environ.copy()
    if author:
        env['GIT_AUTHOR_NAME'] = author
        env['GIT_AUTHOR_EMAIL'] = 'ai@tinyhub.dev'
        env['GIT_COMMITTER_NAME'] = author
        env['GIT_COMMITTER_EMAIL'] = 'ai@tinyhub.dev'
    # Capture git commit status (Fix 10)
    result = subprocess.run(['git', 'commit', '-m', message], cwd=path, env=env, capture_output=True)
    if result.returncode != 0:
        # Commit might fail if there's nothing to commit. That's fine, log it.
        print(f"git commit status: {result.stderr.decode().strip()}")

@app.route('/')
def index():
    # Serve index.html statically from public folder (Fix 14)
    return send_from_directory('public', 'index.html')

@app.route('/api/upload/<proj>', methods=['POST'])
def upload(proj):
    proj = safe_proj(proj)
    if not proj:
        abort(400, 'Invalid project name')
    user = USER
    path = project_path(user, proj)
    git_init_if_needed(path)

    files = request.files.getlist('files')
    blocked = []
    saved = []

    for f in files:
        rel_path = f.filename  # comes as folder/file from webkitdirectory
        safe = safe_rel_path(rel_path)
        if not safe or is_blocked(safe):
            blocked.append(rel_path)
            continue
        full_path = os.path.join(path, safe)
        os.makedirs(os.path.dirname(full_path), exist_ok=True)
        f.save(full_path)
        saved.append(safe)
    
    if saved:
        git_commit(path, f"Upload {len(saved)} files")
    
    return jsonify({'saved': saved, 'blocked': blocked, 'project': proj})

@app.route('/api/commit/<proj>', methods=['POST'])
def ai_commit(proj):
    proj = safe_proj(proj)
    if not proj:
        abort(400, 'Invalid project name')
    auth = request.headers.get('Authorization', '')
    if not auth.startswith('Bearer ') or not hmac.compare_digest(auth, f'Bearer {TOKEN}'):
        abort(401)

    data = request.json
    user = USER
    path = project_path(user, proj)
    git_init_if_needed(path)

    message = data.get('message', 'AI update')
    files = data.get('files', {})

    for rel_path, content in files.items():
        safe = safe_rel_path(rel_path)
        if not safe or is_blocked(safe):
            continue
        full_path = os.path.join(path, safe)
        os.makedirs(os.path.dirname(full_path), exist_ok=True)
        with open(full_path, 'w', encoding='utf-8') as f:
            f.write(content)
    
    git_commit(path, message, author='Meta AI')
    
    return jsonify({'ok': True, 'commit': message})

@app.route('/r/<user>/<proj>/<path:filepath>')
def raw_file(user, proj, filepath):
    if user != USER:
        abort(404)
    proj = safe_proj(proj)
    if not proj:
        abort(400, 'Invalid project name')
    
    path = get_project_path_read(user, proj)
    if not os.path.isdir(path):
        abort(404)
        
    safe = safe_rel_path(filepath)
    if not safe or is_blocked(safe):
        abort(404)
        
    full_filepath = os.path.join(path, safe)
    if not os.path.isfile(full_filepath):
        abort(404)
        
    mime, _ = mimetypes.guess_type(safe)
    if not mime:
        mime = 'text/plain'
    return send_from_directory(path, safe, mimetype=mime)

@app.route('/api/tree/<proj>')
def tree(proj):
    proj = safe_proj(proj)
    if not proj:
        abort(400, 'Invalid project name')
    user = USER
    path = get_project_path_read(user, proj)
    if not os.path.isdir(path):
        return jsonify([])
        
    tree = []
    for root, dirs, files in os.walk(path):
        # skip .git
        dirs[:] = [d for d in dirs if d != '.git']
        for f in files:
            rel = os.path.relpath(os.path.join(root, f), path)
            if is_blocked(rel):
                continue
            tree.append(rel.replace('\\', '/'))
    return jsonify(sorted(tree))

@app.route('/api/history/<proj>')
def history(proj):
    proj = safe_proj(proj)
    if not proj:
        abort(400, 'Invalid project name')
    user = USER
    path = get_project_path_read(user, proj)
    if not os.path.isdir(path) or not os.path.exists(os.path.join(path, '.git')):
        return jsonify([])
    log = subprocess.run(
        ['git', 'log', '--pretty=format:%H%x00%an%x00%ad%x00%s'],
        cwd=path, capture_output=True, text=True
    )
    commits = []
    for line in log.stdout.strip().split('\n'):
        if not line: continue
        parts = line.split('\x00', 3)
        if len(parts) == 4:
            h, an, ad, s = parts
            commits.append({'hash': h[:7], 'author': an, 'date': ad, 'message': s})
    return jsonify(commits)

