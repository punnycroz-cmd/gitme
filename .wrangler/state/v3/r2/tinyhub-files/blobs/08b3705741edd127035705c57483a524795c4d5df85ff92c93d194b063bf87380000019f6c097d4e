import unittest
import os
import tempfile
import shutil
from unittest.mock import patch
import app

class TestAppSanitizers(unittest.TestCase):
    def test_safe_proj(self):
        self.assertEqual(app.safe_proj("my-app"), "my-app")
        self.assertEqual(app.safe_proj("nested/project"), None)
        self.assertEqual(app.safe_proj("../escape"), None)
        self.assertEqual(app.safe_proj("/absolute"), None)
        self.assertEqual(app.safe_proj(""), None)
        self.assertEqual(app.safe_proj("proj\\escaped"), None)

    def test_safe_rel_path(self):
        self.assertEqual(app.safe_rel_path("src/main.js"), "src/main.js")
        self.assertEqual(app.safe_rel_path("main.js"), "main.js")
        self.assertEqual(app.safe_rel_path("../escape.js"), None)
        self.assertEqual(app.safe_rel_path("/absolute.js"), None)
        self.assertEqual(app.safe_rel_path("src/../escape.js"), None)
        self.assertEqual(app.safe_rel_path(""), None)

    def test_is_blocked(self):
        self.assertTrue(app.is_blocked(".env"))
        self.assertTrue(app.is_blocked("src/.env.production"))
        self.assertTrue(app.is_blocked("node_modules/express/index.js"))
        self.assertTrue(app.is_blocked("src/__pycache__/helper.pyc"))
        self.assertTrue(app.is_blocked("id_rsa.pem"))
        self.assertTrue(app.is_blocked("id_rsa.key"))
        self.assertTrue(app.is_blocked("cert.p12"))
        self.assertTrue(app.is_blocked("cert.pfx"))
        self.assertTrue(app.is_blocked(".DS_Store"))
        self.assertTrue(app.is_blocked("Thumbs.db"))
        self.assertTrue(app.is_blocked(".git/config"))
        self.assertTrue(app.is_blocked("dist/bundle.js"))
        self.assertTrue(app.is_blocked("build/index.js"))
        self.assertTrue(app.is_blocked(".next/server.js"))
        self.assertFalse(app.is_blocked("src/main.js"))
        self.assertFalse(app.is_blocked("index.html"))

class TestAppRoutes(unittest.TestCase):
    def setUp(self):
        # Set up a temporary directory to isolate file operations
        self.temp_dir = tempfile.mkdtemp()
        app.BASE_DIR = self.temp_dir
        
        # Enforce a dummy token for test requests
        app.TOKEN = "test_secret_token"
        
        app.app.config['TESTING'] = True
        self.client = app.app.test_client()

    def tearDown(self):
        shutil.rmtree(self.temp_dir)

    def test_index_route(self):
        response = self.client.get('/')
        self.assertEqual(response.status_code, 200)
        response.close()

    def test_tree_route_invalid_proj(self):
        response = self.client.get('/api/tree/proj%5Cescaped')
        self.assertEqual(response.status_code, 400)

    def test_tree_route_empty(self):
        response = self.client.get('/api/tree/test-app')
        self.assertEqual(response.status_code, 200)
        self.assertEqual(response.json, [])

    def test_commit_unauthorized(self):
        response = self.client.post('/api/commit/test-app', 
                                    headers={"Authorization": "Bearer bad_token"},
                                    json={"message": "AI edit", "files": {"main.js": "print(1)"}})
        self.assertEqual(response.status_code, 401)

    @patch('app.git_commit')
    def test_commit_authorized(self, mock_git_commit):
        response = self.client.post('/api/commit/test-app', 
                                    headers={"Authorization": "Bearer test_secret_token"},
                                    json={"message": "AI edit", "files": {"main.js": "print(1)"}})
        self.assertEqual(response.status_code, 200)
        self.assertTrue(response.json['ok'])
        
        # Verify file was written to temp directory
        filepath = os.path.join(self.temp_dir, "andie", "test-app", "main.js")
        self.assertTrue(os.path.exists(filepath))
        with open(filepath, 'r') as f:
            self.assertEqual(f.read(), "print(1)")

    def test_raw_file_cross_user_denied(self):
        response = self.client.get('/r/victim/test-app/main.js')
        self.assertEqual(response.status_code, 404)

    def test_raw_file_blocked_denied(self):
        proj_dir = os.path.join(self.temp_dir, "andie", "test-app")
        os.makedirs(proj_dir, exist_ok=True)
        with open(os.path.join(proj_dir, ".env"), "w") as f:
            f.write("SECRET=123")
            
        response = self.client.get('/r/andie/test-app/.env')
        self.assertEqual(response.status_code, 404)

    def test_raw_file_not_found(self):
        response = self.client.get('/r/andie/test-app/nonexistent.js')
        self.assertEqual(response.status_code, 404)

    @patch('app.git_commit')
    def test_upload_blocked_files_and_traversal(self, mock_git_commit):
        import io
        data = {
            'files': [
                (io.BytesIO(b"print(1)"), 'main.js'),
                (io.BytesIO(b"SECRET=123"), '.env'),
                (io.BytesIO(b"hack"), 'folder/../../escape.js')
            ]
        }
        response = self.client.post('/api/upload/test-app', data=data, content_type='multipart/form-data')
        self.assertEqual(response.status_code, 200)
        self.assertIn('main.js', response.json['saved'])
        self.assertNotIn('.env', response.json['saved'])
        self.assertNotIn('folder/../../escape.js', response.json['saved'])
        self.assertIn('.env', response.json['blocked'])

        proj_dir = os.path.join(self.temp_dir, "andie", "test-app")
        self.assertTrue(os.path.exists(os.path.join(proj_dir, "main.js")))
        self.assertFalse(os.path.exists(os.path.join(proj_dir, ".env")))
        self.assertFalse(os.path.exists(os.path.join(self.temp_dir, "escape.js")))

if __name__ == '__main__':
    unittest.main()
