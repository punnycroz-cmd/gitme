rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /projects/{user}/{proj}/{file=**} {
      allow read: if true;  // intentionally public for demo
      allow write: if false; // only Cloud Functions (Admin SDK) can write
    }
    match /{allPaths=**} {
      allow read, write: if false; // deny access to any other paths
    }
  }
}
