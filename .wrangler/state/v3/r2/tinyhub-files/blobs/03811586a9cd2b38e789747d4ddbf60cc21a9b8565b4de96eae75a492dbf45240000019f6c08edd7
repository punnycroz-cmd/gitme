const fs = require('fs');
const path = require('path');
const { execSync } = require('child_process');

console.log('🔍 Running pre-deployment checks...');

// 1. Check .firebaserc
const rcPath = path.join(__dirname, '.firebaserc');
if (!fs.existsSync(rcPath)) {
  console.error('❌ Error: .firebaserc is missing!');
  process.exit(1);
}

try {
  const rc = JSON.parse(fs.readFileSync(rcPath, 'utf8'));
  const proj = rc.projects?.default;
  if (!proj || proj === 'your-firebase-project-id') {
    console.error('❌ Error: .firebaserc default project is still set to placeholder "your-firebase-project-id"!');
    process.exit(1);
  }
  console.log(`✅ Default Firebase project configured: "${proj}"`);
} catch (e) {
  console.error('❌ Error parsing .firebaserc:', e.message);
  process.exit(1);
}

// 2. Warn about runtime env/secrets if firebase-tools is installed
try {
  console.log('Checking functions config...');
  const configRaw = execSync('npx firebase functions:config:get', { encoding: 'utf8', stdio: ['pipe', 'pipe', 'ignore'] });
  const config = JSON.parse(configRaw);
  
  if (!config.tinyhub?.token) {
    console.warn('⚠️ Warning: tinyhub.token is not set in Firebase Functions config! Client commits will fail.');
  } else {
    console.log('✅ tinyhub.token config is set.');
  }
  
  if (!config.tinyhub?.signing_secret) {
    console.warn('⚠️ Warning: tinyhub.signing_secret is not set in Firebase Functions config! GET commit workaround will fail.');
  } else {
    console.log('✅ tinyhub.signing_secret config is set.');
  }
} catch (e) {
  console.log('⚠️ Could not fetch remote functions config (perhaps firebase login is required or project does not exist yet). Please verify config values manually.');
}

console.log('🎉 Pre-deployment checks completed.');
